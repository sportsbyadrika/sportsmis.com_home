# SportsMIS env example. Copy to app/.env on the server and fill in real values.
# app/.env is gitignored and read by app/public/index.php on every request
# (manual line parser → putenv). Never commit a populated .env.

# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET=change-this-secret-key-in-production

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sportsmis
DB_USERNAME=
DB_PASSWORD=

# ── Mail (SMTP) ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@sportsmis.com
MAIL_FROM_NAME=SportsMIS

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.sportsmis.com/auth/google/callback

# ── Razorpay (ePayment) ─────────────────────────────────────────────────────
# Get test keys from https://dashboard.razorpay.com → Settings → API Keys.
# Switch to live keys (rzp_live_…) only after the dashboard activates the
# account. KEY_SECRET MUST stay secret — never check it in.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=

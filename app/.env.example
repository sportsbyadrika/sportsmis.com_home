APP_ENV=production
APP_SECRET=your-random-secret-key-here

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sportsmis
DB_USERNAME=sportsmis_user
DB_PASSWORD=strong_password_here

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@sportsmis.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@sportsmis.com
MAIL_FROM_NAME="SportsMIS"

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://app.sportsmis.com/auth/google/callback

# ── Razorpay (ePayment) ───────────────────────────────────────────────
# Standard Checkout flow — no "return URL" is registered. The browser
# round-trip handler hits /athlete/events/{id}/pay/verify and the
# Razorpay dashboard webhook hits /webhook/razorpay (server-to-server).
#
# Set in Razorpay Dashboard:
#   1. Account & Settings → API Keys → Generate (test or live)
#      → copy KEY_ID and KEY_SECRET below
#   2. Account & Settings → Webhooks → Add New Webhook
#      URL    : https://app.sportsmis.com/webhook/razorpay
#      Events : payment.captured, payment.failed, order.paid
#      Secret : generate a strong random string and paste below
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

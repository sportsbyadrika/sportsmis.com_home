# Redirect all traffic to public/ (when the web root is mistakenly set to app/).
RewriteEngine On
RewriteRule ^(.*)$ public/$1 [L]

# Defence in depth: explicitly deny direct access to secret-bearing files
# regardless of any rewrite. .env / .sql / .log / dotfiles must never be
# served if Apache happens to resolve a request to them inside app/.
<FilesMatch "(^\.|\.(env|sql|log|md|ini|bak)$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# Server-side session data lifetime — keep PHP's session files alive for
# 2 hours so they match the cookie lifetime the app sets in
# app/public/index.php. Without this, cPanel's default gc_maxlifetime
# (often 1440 = 24 minutes) silently expires sessions early.
# Wrapped in IfModule so PHP-FPM hosts that forbid php_value don't 500.
<IfModule mod_php.c>
    php_value session.gc_maxlifetime 7200
</IfModule>
<IfModule mod_php7.c>
    php_value session.gc_maxlifetime 7200
</IfModule>
<IfModule mod_php8.c>
    php_value session.gc_maxlifetime 7200
</IfModule>
<IfModule lsapi_module>
    php_value session.gc_maxlifetime 7200
</IfModule>

# Environment
app/.env
*.env

# Uploads (user files - not versioned, but keep folder skeleton)
app/public/assets/uploads/**
!app/public/assets/uploads/
!app/public/assets/uploads/**/
!app/public/assets/uploads/**/.gitkeep

# Logs
*.log
app/logs/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# App config (per-environment)
app/config/app.php
app/config/database.php

# Generated certificate PDFs — created at runtime, never committed.
storage/certificates/**
!storage/certificates/
!storage/certificates/.gitkeep

# Dompdf font cache / temp files — created at runtime, never committed.
storage/dompdf/
